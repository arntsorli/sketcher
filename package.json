{
  "name": "sketcher",
  "version": "0.1.3",
  "description": "A local-first Windows architecture modeller for concept design.",
  "license": "MIT",
  "author": "Arnt Sorli",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "package": "npm run build && electron-builder --win nsis portable --publish never",
    "smoke": "npm run build && node scripts/smoke.mjs",
    "typecheck": "tsc --noEmit",
    "check": "biome check .",
    "format": "biome check --write .",
    "icon": "node scripts/build-icon.mjs",
    "test": "vitest",
    "ci": "npm run check && npm run typecheck && npm test -- --run && npm run build"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "1.1.19",
    "fflate": "0.8.3",
    "geotiff": "3.0.5",
    "manifold-3d": "3.5.1",
    "maplibre-gl": "5.24.0",
    "proj4": "2.20.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "three": "0.185.1",
    "zod": "4.4.3",
    "zustand": "5.0.14"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.3",
    "@testing-library/react": "16.3.2",
    "@types/node": "26.1.1",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@types/three": "0.185.0",
    "@vitejs/plugin-react": "5.2.0",
    "electron": "43.1.0",
    "electron-builder": "26.15.3",
    "electron-vite": "5.0.0",
    "jsdom": "29.1.1",
    "playwright": "^1.61.1",
    "png-to-ico": "^3.0.2",
    "sharp": "^0.35.3",
    "typescript": "6.0.3",
    "vite": "7.3.6",
    "vitest": "4.1.10"
  }
}
